{
  "name": "keyshield",
  "productName": "KeyShield",
  "version": "1.0.0",
  "description": "A cross-platform utility that disables the keyboard so you can safely clean it.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "keyboard",
    "lock",
    "clean",
    "utility",
    "electron"
  ],
  "author": "Atishay Kumar",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.keyshield.app",
    "productName": "KeyShield",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "directories": {
      "output": "dist"
    }
  }
}
